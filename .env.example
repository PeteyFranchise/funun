# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic — server-side only, never exposed to client
ANTHROPIC_API_KEY=your_anthropic_api_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_YEARLY=price_...
STRIPE_PRICE_FOUNDING=price_...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=pete@funun.studio
# Monitored mailbox used as sender AND reply-to for Funūn's split-sheet
# signature invites (17-10). Collaborator replies land here, so it must be a
# real, monitored inbox on a domain verified with Resend — not a no-reply.
ESIGN_FROM_EMAIL=esign@funun.studio
# DocuSeal e-signature provider (Phase 17). Server-only — exposing either
# value to the client would let anyone mint or forge envelopes.
# API token: DocuSeal dashboard -> API -> X-Auth-Token
DOCUSEAL_API_KEY=
# Webhook signing secret (whsec_-prefixed, used as-is — do not strip the
# prefix or base64-decode it). DocuSeal dashboard -> Webhooks
DOCUSEAL_WEBHOOK_SECRET=

# DDEX — sender Party ID for metadata exports; falls back to a placeholder if unset
DDEX_DPID=

# App
# Local dev: http://localhost:3000  ·  Production: https://funun.studio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" only for demo mode (hides the real backend); leave unset/false in prod
NEXT_PUBLIC_VAULT_DEMO=
