# Copy to .env.test (gitignored) and fill in. Used by the Phase 11/12 messaging,
# presence and Green Room E2E suite.

# Where to run the suite. `next dev` must already be running against it -
# there's no webServer block in playwright.config.ts.
E2E_BASE_URL=http://localhost:3000

# Three real accounts on the target deployment. The seed script wires the
# relationships the DM send-gate branches on:
#   A - the viewer most specs act as
#   B - seeded as an accepted CONNECTION of A, so A->B sends go direct
#   C - left a STRANGER to A, so A->C sends open a cold message request
E2E_USER_A_EMAIL=
E2E_USER_A_PASSWORD=
E2E_USER_B_EMAIL=
E2E_USER_B_PASSWORD=
E2E_USER_C_EMAIL=
E2E_USER_C_PASSWORD=

# Supabase project the deployment uses. `npm run e2e:seed` needs the service
# role for two reasons: to create the synthetic rate-limit recipients via the
# admin auth API, and because migration 056 revoked authenticated INSERT on
# dm_threads / dm_messages - the service client is the only way to seed them.
# Keep this file out of git (it already is via .gitignore).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NOTE: NEXT_PUBLIC_VAULT_DEMO must NOT be true on the target. Every DM,
# presence and Green Room route returns a canned success in demo mode, so the
# suite would pass without testing anything. Setup asserts this and fails loudly.
