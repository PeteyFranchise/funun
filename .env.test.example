# Copy to .env.test (gitignored) and fill in. Used by the Phase 14 UAT E2E suite.

# Where to run the suite:
#   local dev  -> http://localhost:3000 (default)
#   PR preview -> the Vercel preview URL (required for the @live specs 1 and 3)
E2E_BASE_URL=http://localhost:3000

# Two real accounts on the target deployment.
# User A owns the seeded projects; User B is used for the cross-tenant checks.
E2E_USER_A_EMAIL=
E2E_USER_A_PASSWORD=
E2E_USER_B_EMAIL=
E2E_USER_B_PASSWORD=

# Supabase project the deployment uses - needed by `npm run e2e:seed` to create
# the test projects and upload backing files. Service role bypasses RLS, so keep
# this file out of git (it already is via .gitignore).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: size of the stems ZIP for checkpoint 1 (MB). Set 240 for the ~250MB
# upper-bound run. Default 8 (over the 4.5MB Hobby body limit).
# E2E_STEMS_MB=8

# Optional: a project owned by User A with a deliberately-missing storage object,
# to exercise WR-01 (clean failure). Leave unset to skip that check.
# E2E_WR01_PROJECT_ID=

# Optional overrides if you seed by hand instead of `npm run e2e:seed`:
# E2E_FULL_PROJECT_ID=
# E2E_FULL_TRACK_ID=
# E2E_UPLOAD_PROJECT_ID=
# E2E_UPLOAD_TRACK_ID=
# E2E_OWNER_A_ID=
# E2E_OWNER_B_ID=
